<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="Panel">
        <item name="android:background">@drawable/panel_bg</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="Heading">
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <style name="Label">
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Input">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">#687985</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">11dp</item>
    </style>

    <style name="Hint">
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:paddingTop">9dp</item>
    </style>

    <style name="ButtonPrimary" parent="android:style/Widget.Material.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:backgroundTint">@color/accent_dark</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="ButtonSecondary" parent="ButtonPrimary">
        <item name="android:backgroundTint">@color/stroke</item>
    </style>

    <style name="ButtonDanger" parent="ButtonPrimary">
        <item name="android:backgroundTint">@color/danger</item>
    </style>

    <style name="TabButton" parent="android:style/Widget.Material.Button.Borderless">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
        <item name="android:backgroundTint">#131A20</item>
    </style>

    <style name="CompactButton" parent="android:style/Widget.Material.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:backgroundTint">@color/stroke</item>
        <item name="android:minWidth">50dp</item>
        <item name="android:minHeight">38dp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
    </style>
</resources>
