<?xml version="1.0" encoding="utf-8"?>
<!-- REFERENCE ONLY: v1.1 builds the active UI programmatically in MainActivity.java. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无线 ADB 工具箱"
            android:textColor="@color/text"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="配对 · 连接 · APK 推送 · Shell · 设备信息"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/status_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:id="@+id/statusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="@color/danger"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="未连接"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusEndpointText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="尚未建立 ADB 通道"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#131A20"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <Button
            android:id="@+id/tabConnection"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="连接" />

        <Button
            android:id="@+id/tabApk"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="APK" />

        <Button
            android:id="@+id/tabShell"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Shell" />

        <Button
            android:id="@+id/tabDevice"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="设备" />

        <Button
            android:id="@+id/tabLog"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="日志" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/pageContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/pageConnection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/Panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Heading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="无线 ADB" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设备 IP 地址" />

                    <EditText
                        android:id="@+id/ipInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="例如 192.168.1.88"
                        android:inputType="textUri"
                        android:singleLine="true" />

                    <TextView
                        style="@style/SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="第一步：配对（Android 11+ 首次使用）" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="配对页面端口" />

                    <EditText
                        android:id="@+id/pairPortInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="无线调试 → 使用配对码配对设备"
                        android:inputType="number"
                        android:singleLine="true" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6 位配对码" />

                    <EditText
                        android:id="@+id/pairCodeInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="123456"
                        android:inputType="numberPassword"
                        android:maxLength="6"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/pairButton"
                        style="@style/ButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="配对设备" />

                    <TextView
                        style="@style/SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="第二步：连接" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="无线调试连接端口" />

                    <EditText
                        android:id="@+id/connectPortInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="例如 37099；传统 TCP ADB 通常为 5555"
                        android:inputType="number"
                        android:singleLine="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/connectButton"
                            style="@style/ButtonPrimary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="连接" />

                        <Button
                            android:id="@+id/disconnectButton"
                            style="@style/ButtonDanger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:text="断开" />
                    </LinearLayout>

                    <TextView
                        style="@style/Hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Android 11+ 的配对端口和连接端口通常不同。完成配对后，请返回“无线调试”主页面读取连接端口。" />
                </LinearLayout>

                <Space
                    android:layout_width="1dp"
                    android:layout_height="24dp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageApk"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/Panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Heading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APK 推送与安装" />

                    <TextView
                        android:id="@+id/apkNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:text="尚未选择 APK"
                        android:textColor="@color/muted"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/selectApkButton"
                        style="@style/ButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="从本机存储选择 APK" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="远程保存路径" />

                    <EditText
                        android:id="@+id/remotePathInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="/data/local/tmp/app.apk"
                        android:inputType="textNoSuggestions"
                        android:singleLine="true" />

                    <CheckBox
                        android:id="@+id/deleteRemoteCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/accent"
                        android:text="安装成功后删除远程临时 APK"
                        android:textColor="@color/text" />

                    <ProgressBar
                        android:id="@+id/apkProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/accent"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/apkProgressText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="准备就绪"
                        android:textColor="@color/muted"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/pushOnlyButton"
                            style="@style/ButtonSecondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="仅推送" />

                        <Button
                            android:id="@+id/pushInstallButton"
                            style="@style/ButtonPrimary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:text="推送并安装" />
                    </LinearLayout>

                    <TextView
                        style="@style/Hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="系统文件选择器无需“读取全部存储”权限。安装命令使用 pm install -r，可覆盖更新同签名应用。" />
                </LinearLayout>

                <Space
                    android:layout_width="1dp"
                    android:layout_height="24dp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageShell"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/Panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Heading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shell 命令" />

                    <EditText
                        android:id="@+id/shellInput"
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:hint="例如 pm list packages"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:maxLines="8"
                        android:minLines="4" />

                    <Button
                        android:id="@+id/runShellButton"
                        style="@style/ButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="执行命令并打开日志" />

                    <TextView
                        style="@style/Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="快捷命令" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/quickPackages"
                                style="@style/ButtonSecondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="第三方包" />

                            <Button
                                android:id="@+id/quickSize"
                                style="@style/ButtonSecondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="7dp"
                                android:text="分辨率" />

                            <Button
                                android:id="@+id/quickBattery"
                                style="@style/ButtonSecondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="7dp"
                                android:text="电池" />

                            <Button
                                android:id="@+id/quickModel"
                                style="@style/ButtonSecondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="7dp"
                                android:text="型号" />

                            <Button
                                android:id="@+id/quickScreenshot"
                                style="@style/ButtonSecondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="7dp"
                                android:text="截图" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <TextView
                        style="@style/Hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="命令输出会实时写入独立日志页。截图快捷键保存到远程设备 /sdcard/adbtoolbox-screen.png。" />
                </LinearLayout>

                <Space
                    android:layout_width="1dp"
                    android:layout_height="24dp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageDevice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/Panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Heading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设备信息" />

                    <Button
                        android:id="@+id/infoButton"
                        style="@style/ButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="刷新设备信息" />

                    <TextView
                        android:id="@+id/deviceInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:lineSpacingMultiplier="1.25"
                        android:minHeight="190dp"
                        android:padding="14dp"
                        android:text="连接设备后点击刷新。"
                        android:textColor="@color/text"
                        android:textIsSelectable="true"
                        android:textSize="14sp" />
                </LinearLayout>

                <Space
                    android:layout_width="1dp"
                    android:layout_height="24dp" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/pageLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/pauseAutoScrollCheck"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/accent"
                    android:text="暂停自动滚动"
                    android:textColor="@color/text"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/copyLogButton"
                    style="@style/CompactButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="复制" />

                <Button
                    android:id="@+id/saveLogButton"
                    style="@style/CompactButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:text="保存" />

                <Button
                    android:id="@+id/clearLogButton"
                    style="@style/CompactButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:text="清空" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:background="@drawable/terminal_bg"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/logText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.12"
                    android:minHeight="300dp"
                    android:textColor="@color/terminal_text"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
